<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFEDD8"
    tools:context=".formulario_recetarium">

    <TextView
        android:id="@+id/textView"
        android:layout_width="202dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="193dp"
        android:text="@string/label_nombre_receta"
        android:textColor="#507561"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/etNombrePlato"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="138dp"
        android:layout_height="53dp"
        android:layout_marginStart="51dp"
        android:layout_marginTop="260dp"
        android:layout_marginEnd="46dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#8AC8A6"
        android:text="@string/btn_volver"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnGuardarReceta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labelsContainer" />

    <Button
        android:id="@+id/btnGuardarReceta"
        android:layout_width="138dp"
        android:layout_height="53dp"
        android:layout_marginStart="46dp"
        android:layout_marginTop="260dp"
        android:layout_marginEnd="38dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#8AC8A6"
        android:text="@string/btn_guardar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnVolver"
        app:layout_constraintTop_toBottomOf="@+id/labelsContainer"
        app:layout_constraintVertical_bias="0.518" />

    <TextView
        android:id="@+id/etNombrePlato"
        android:layout_width="329dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="66dp"
        android:layout_marginBottom="15dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="#344D3F"
        app:layout_constraintBottom_toTopOf="@+id/textView2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <TextView
        android:id="@+id/etPasosReceta"
        android:layout_width="326dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="69dp"
        android:layout_marginBottom="18dp"
        android:gravity="top"
        android:hint="@string/label_pasos"
        android:maxHeight="200dp"
        android:minLines="4"
        android:scrollbars="vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="#344D3F"
        app:layout_constraintBottom_toTopOf="@+id/textView3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

    <LinearLayout
        android:id="@+id/labelsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="69dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3">

        <TextView
            android:id="@+id/tvDish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_dish_plain"
            android:textColor="#507561" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_time_plain"
            android:textColor="#507561" />

        <TextView
            android:id="@+id/tvFoodType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_foodtype_plain"
            android:textColor="#507561" />

    </LinearLayout>

    <!-- Action buttons (Edit / Delete) placed above the bottom row -->

    <LinearLayout
        android:id="@+id/actionButtonsTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/btnVolver"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labelsContainer"
        app:layout_constraintVertical_bias="0.877">

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="138dp"
            android:layout_height="53dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#8AC8A6"
            android:text="@string/btn_editar" />

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="138dp"
            android:layout_height="53dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#8AC8A6"
            android:text="@string/btn_eliminar" />

    </LinearLayout>

    <TextView
        android:id="@+id/textView3"
        android:layout_width="202dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="193dp"
        android:text="@string/label_etiquetas"
        android:textColor="#507561"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/labelsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etPasosReceta" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="202dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="193dp"
        android:text="Pasos para el plato:"
        android:textColor="#507561"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/etPasosReceta"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etNombrePlato" />

</androidx.constraintlayout.widget.ConstraintLayout>