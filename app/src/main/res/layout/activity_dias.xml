<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFEDD8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título de la semana -->
        <TextView
            android:id="@+id/tvTituloSemana"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="Semana del 04 – 10 de Mayo 2026"
            android:textColor="#507561"
            android:textSize="16sp" />

        <!-- Fila 1: LUNES y MARTES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <!-- LUNES -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#8AC8A6"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="LUNES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvLunes"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="#F5F5F5"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="vacio"
                    android:textColor="#333333"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- MARTES -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#8AC8A6"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="MARTES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvMartes"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="#F5F5F5"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="vacio"
                    android:textColor="#333333"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Fila 2: MIERCOLES y JUEVES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <!-- MIERCOLES -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#8AC8A6"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="MIERCOLES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvMiercoles"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="#F5F5F5"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="vacio"
                    android:textColor="#333333"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- JUEVES -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#8AC8A6"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="JUEVES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvJueves"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="#F5F5F5"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="vacio"
                    android:textColor="#333333"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Fila 3: VIERNES y SABADO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <!-- VIERNES -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#8AC8A6"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="VIERNES"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvViernes"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="#F5F5F5"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="vacio"
                    android:textColor="#333333"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- SABADO -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#8AC8A6"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="SABADO"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvSabado"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="#F5F5F5"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="vacio"
                    android:textColor="#333333"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Fila 4: DOMINGO (centrado) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#8AC8A6"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="DOMINGO"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvDomingo"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="#F5F5F5"
                android:gravity="center"
                android:padding="8dp"
                android:text="vacio"
                android:textColor="#333333"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Botón Volver -->
        <Button
            android:id="@+id/btnVolver"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#8AC8A6"
            android:text="Volver"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>