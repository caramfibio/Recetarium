<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4BB633"
    android:backgroundTint="#2E4313"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/BtnRecetarium"
        android:layout_width="204dp"
        android:layout_height="46dp"
        android:layout_marginStart="103dp"
        android:layout_marginEnd="104dp"
        android:layout_marginBottom="98dp"
        android:backgroundTint="#82C820"
        android:text="@string/btn_gestion"
        app:layout_constraintBottom_toTopOf="@+id/BtnGenerarMain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <Button
        android:id="@+id/BtnHistorial"
        android:layout_width="204dp"
        android:layout_height="46dp"
        android:layout_marginStart="103dp"
        android:layout_marginEnd="104dp"
        android:layout_marginBottom="436dp"
        android:backgroundTint="#639918"
        android:text="@string/btn_menus_semanales"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/BtnRecetarium" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="114dp"
        android:layout_height="114dp"
        android:layout_marginStart="148dp"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="149dp"
        android:layout_marginBottom="51dp"
        app:layout_constraintBottom_toTopOf="@+id/BtnRecetarium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/presence_online"
        android:contentDescription="@string/img_main_desc" />
</androidx.constraintlayout.widget.ConstraintLayout>