<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4BB633"
    android:backgroundTint="#CFEDD8"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvLunes2"
        android:layout_width="322dp"
        android:layout_height="83dp"
        android:layout_marginStart="45dp"
        android:layout_marginEnd="45dp"
        android:layout_marginBottom="50dp"
        android:background="#F5F5F5"
        android:gravity="center"
        android:padding="8dp"
        android:text="@string/empty_text"
        android:textColor="#333333"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@+id/BtnRecetarium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView5" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="322dp"
        android:layout_height="21dp"
        android:layout_marginStart="45dp"
        android:layout_marginTop="91dp"
        android:layout_marginEnd="45dp"
        android:background="#8AC8A6"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="@string/day_lunes"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        app:layout_constraintBottom_toTopOf="@+id/tvLunes2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <Button
        android:id="@+id/BtnRecetarium"
        android:layout_width="204dp"
        android:layout_height="46dp"
        android:layout_marginStart="103dp"
        android:layout_marginTop="47dp"
        android:layout_marginEnd="104dp"
        android:layout_marginBottom="19dp"
        android:backgroundTint="#8AC8A6"
        android:text="@string/btn_gestion"
        app:layout_constraintBottom_toTopOf="@+id/BtnHistorial"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvLunes2" />

    <Button
        android:id="@+id/BtnHistorial"
        android:layout_width="204dp"
        android:layout_height="46dp"
        android:layout_marginStart="103dp"
        android:layout_marginTop="19dp"
        android:layout_marginEnd="104dp"
        android:layout_marginBottom="64dp"
        android:backgroundTint="#8AC8A6"
        android:text="@string/btn_menus_semanales"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/BtnRecetarium" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="278dp"
        android:layout_height="223dp"
        android:layout_marginStart="148dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="149dp"
        android:contentDescription="@string/img_main_desc"
        app:layout_constraintBottom_toTopOf="@+id/textView5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/logo_recetario" />
</androidx.constraintlayout.widget.ConstraintLayout>