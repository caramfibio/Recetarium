<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#2D5A27"
    android:padding="16dp">

    <!-- Espacio superior -->
    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"/>

    <!-- ===== SEMANA 1 ===== -->
    <LinearLayout
        android:id="@+id/layoutSemana1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <!-- Cabecera de días -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="L"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#5B9BD5"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="M"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#70AD47"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="X"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#C00000"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="J"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#FFD966"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="V"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#70AD47"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1.5"
                android:text="S y D"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="#A9D18E"
                android:layout_marginStart="2dp"/>
        </LinearLayout>

        <!-- Fila de celdas semana 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#C8E6C9"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#C8E6C9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== SEMANA 2 ===== -->
    <LinearLayout
        android:id="@+id/layoutSemana2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="40dp">

        <!-- Cabecera de días -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="L"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#5B9BD5"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="M"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#70AD47"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="X"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#C00000"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="J"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#FFD966"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="V"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="#70AD47"
                android:layout_marginStart="2dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1.5"
                android:text="S y D"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="#A9D18E"
                android:layout_marginStart="2dp"/>
        </LinearLayout>

        <!-- Fila de celdas semana 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:background="#D9D9D9"
                android:layout_marginStart="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Espaciador flexible -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Botón Volver -->
    <Button
        android:id="@+id/btnVolver"
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:text="Volver"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5CB85C"
        android:layout_marginBottom="30dp"/>

</LinearLayout>